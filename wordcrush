<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pi Sayısının Gizemi | Performans Görevi PRO</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap');

        :root {
            --primary-color: #00d2ff;
            --secondary-color: #3a7bd5;
            --bg-color: #0f172a;
            --text-color: #f8fafc;
            --card-bg: #1e293b;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            margin: 0;
            overflow-x: hidden;
        }

        /* --- BAŞLIK VE GİRİŞ --- */
        header {
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            background: radial-gradient(circle at center, #1e293b 0%, #0f172a 100%);
            text-align: center;
            position: relative;
        }

        .pi-symbol {
            font-size: 8rem;
            color: var(--primary-color);
            text-shadow: 0 0 20px var(--primary-color);
            animation: float 3s ease-in-out infinite;
            cursor: pointer;
        }

        @keyframes float {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-20px); }
            100% { transform: translateY(0px); }
        }

        h1 { font-size: 3.5rem; margin: 10px 0; letter-spacing: 2px; }
        .subtitle { font-size: 1.2rem; color: #94a3b8; max-width: 600px; margin-bottom: 20px; }
        .scroll-down { margin-top: 30px; font-size: 1rem; color: #64748b; animation: pulse 2s infinite; }

        @keyframes pulse { 0%, 100% {opacity: 1;} 50% {opacity: 0.5;} }

        .container { max-width: 1100px; margin: 0 auto; padding: 60px 20px; }

        /* --- TIKLANABİLİR BİLGİ KARTLARI --- */
        .section-title { text-align: center; font-size: 2.5rem; margin-bottom: 40px; color: var(--primary-color); }
        
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; }
        
        .card {
            background: rgba(255, 255, 255, 0.05);
            padding: 30px;
            border-radius: 20px;
            border-top: 4px solid var(--primary-color);
            backdrop-filter: blur(10px);
            cursor: pointer;
            transition: all 0.4s ease;
            text-align: center;
        }

        .card:hover {
            transform: translateY(-10px) scale(1.02);
            box-shadow: 0 10px 30px rgba(0, 210, 255, 0.2);
            background: rgba(255, 255, 255, 0.1);
        }

        .card h3 { color: var(--primary-color); font-size: 1.5rem; margin-top: 0; }
        .card p { color: #cbd5e1; }
        .click-hint { display: block; margin-top: 15px; font-size: 0.85rem; color: #00d2ff; font-weight: bold; }

        /* --- MODAL (POP-UP) PENCERELERİ --- */
        .modal {
            display: none; 
            position: fixed; 
            z-index: 1000; 
            left: 0; top: 0; 
            width: 100%; height: 100%; 
            background-color: rgba(0,0,0,0.8); 
            backdrop-filter: blur(5px);
            align-items: center; justify-content: center;
        }

        .modal-content {
            background-color: var(--card-bg);
            padding: 40px;
            border-radius: 20px;
            width: 80%;
            max-width: 700px;
            border: 2px solid var(--primary-color);
            position: relative;
            box-shadow: 0 0 40px rgba(0, 210, 255, 0.4);
            animation: zoomIn 0.3s ease;
        }

        @keyframes zoomIn { from {transform: scale(0.8); opacity: 0;} to {transform: scale(1); opacity: 1;} }

        .close-btn {
            position: absolute; right: 25px; top: 20px;
            font-size: 30px; color: #94a3b8; cursor: pointer; transition: 0.3s;
        }
        .close-btn:hover { color: #ef4444; }

        /* --- NE ÖĞRENMEK İSTERSİN (AKORDEON) --- */
        .faq-section {
            background: rgba(255, 255, 255, 0.05);
            padding: 40px;
            border-radius: 20px;
            margin: 80px 0;
        }

        .faq-item {
            background: var(--bg-color);
            margin-bottom: 15px;
            border-radius: 10px;
            cursor: pointer;
            overflow: hidden;
            border-left: 3px solid transparent;
            transition: 0.3s;
        }

        .faq-item:hover { border-left-color: var(--primary-color); }

        .faq-question {
            padding: 20px;
            font-weight: bold;
            font-size: 1.1rem;
            display: flex;
            justify-content: space-between;
            color: #e2e8f0;
        }

        .faq-answer {
            max-height: 0;
            padding: 0 20px;
            background: #1e293b;
            color: #94a3b8;
            transition: all 0.4s ease-out;
            opacity: 0;
        }

        .faq-item.active .faq-answer {
            max-height: 500px; /* İçeriğe göre yüksekliği açar */
            padding: 20px;
            opacity: 1;
            border-top: 1px solid #334155;
        }
        
        .faq-item.active .faq-question { color: var(--primary-color); }

        /* --- SİMÜLASYON --- */
        .interactive-section {
            background: linear-gradient(135deg, var(--secondary-color), var(--primary-color));
            padding: 50px;
            border-radius: 30px;
            text-align: center;
            margin: 80px 0;
            color: white;
            box-shadow: 0 15px 40px rgba(0, 210, 255, 0.3);
        }

        input { padding: 15px; border-radius: 10px; border: none; margin: 10px; width: 220px; font-size: 1rem; outline: none; }
        button { padding: 15px 40px; background: #0f172a; color: #00d2ff; border: none; border-radius: 10px; font-size: 1.1rem; font-weight: bold; cursor: pointer; transition: 0.3s; margin-top: 15px; }
        button:hover { background: white; color: var(--secondary-color); }

        footer { text-align: center; padding: 30px; border-top: 1px solid #334155; color: #64748b; }
    </style>
</head>
<body>

    <!-- GİRİŞ -->
    <header>
        <div class="pi-symbol">&pi;</div>
        <h1>Pi'nin Gizemi</h1>
        <p class="subtitle">Çemberin kalbine yapılan sonsuz bir yolculuk.</p>
        <div class="scroll-down">Keşfetmek İçin Aşağı Kaydır ↓</div>
    </header>

    <div class="container">
        
        <h2 class="section-title">Temel Bilgiler</h2>
        
        <!-- TIKLANABİLİR KARTLAR -->
        <div class="grid">
            <div class="card" onclick="openModal('modal1')">
                <h3>🔍 Pi Sayısı Nedir?</h3>
                <p>Bir çemberin çevresinin çapına bölümüdür. Evrensel bir sabittir.</p>
                <span class="click-hint">Daha Fazla Bilgi İçin Tıkla →</span>
            </div>
            <div class="card" onclick="openModal('modal2')">
                <h3>♾️ Sonsuzluk ve Düzensizlik</h3>
                <p>Virgülden sonrası sonsuza dek hiçbir örüntüye uymadan gider.</p>
                <span class="click-hint">Daha Fazla Bilgi İçin Tıkla →</span>
            </div>
            <div class="card" onclick="openModal('modal3')">
                <h3>🚀 Neden Çok Önemli?</h3>
                <p>Sadece geometride değil uzay bilimleri ve mimaride kullanılır.</p>
                <span class="click-hint">Daha Fazla Bilgi İçin Tıkla →</span>
            </div>
        </div>

        <!-- YENİ BÖLÜM: NE ÖĞRENMEK İSTERSİN? -->
        <div class="faq-section">
            <h2 class="section-title" style="margin-bottom: 20px;">Ne Öğrenmek İstersin?</h2>
            <p style="text-align: center; color: #94a3b8; margin-bottom: 40px;">Merak ettiğiniz sorunun üzerine tıklayın.</p>
            
            <div class="faq-item" onclick="toggleFAQ(this)">
                <div class="faq-question">Pi Gününü neden kutluyoruz? <span>+</span></div>
                <div class="faq-answer">
                    Pi sayısı 3,14 ile başladığı için her yıl 3. ayın 14. günü (14 Mart) Dünya Pi Günü olarak kutlanır. Aynı zamanda bu tarih ünlü fizikçi Albert Einstein'ın doğum günüdür!
                </div>
            </div>

            <div class="faq-item" onclick="toggleFAQ(this)">
                <div class="faq-question">İçinde doğum tarihimiz gizli mi? <span>+</span></div>
                <div class="faq-answer">
                    Evet! Pi irrasyonel bir sayı olduğu için sonsuz basamağa sahiptir ve rakamlar tamamen düzensizdir. Bu matematikte şu anlama gelir: Dünyadaki herkesin doğum tarihi, telefon numarası veya TC kimlik numarası Pi'nin basamakları içinde bir yerlerde peş peşe kesinlikle yer alır!
                </div>
            </div>

            <div class="faq-item" onclick="toggleFAQ(this)">
                <div class="faq-question">Doğada Pi sayısını görebilir miyiz? <span>+</span></div>
                <div class="faq-answer">
                    Sadece çemberlerde değil! Örneğin bir nehrin gerçek uzunluğunun, nehrin kaynağı ile döküldüğü yer arasındaki kuş uçuşu mesafesine oranı ortalama olarak Pi sayısına (3,14) eşittir. Einstein, bunun nehirlerin kıvrım yapma eğilimiyle ilgili olduğunu kanıtlamıştır.
                </div>
            </div>

            <div class="faq-item" onclick="toggleFAQ(this)">
                <div class="faq-question">En fazla kaç basamağı hesaplandı? <span>+</span></div>
                <div class="faq-answer">
                    Günümüzde süper bilgisayarlar kullanılarak Pi sayısının 100 Trilyondan fazla basamağı hesaplanmıştır. Ancak NASA'ya göre Güneş sistemimizin en uzak noktasına gönderilecek bir uzay aracının rotasını hesaplamak için Pi'nin sadece ilk 15 basamağı yeterlidir!
                </div>
            </div>
        </div>

        <!-- SİMÜLASYON -->
        <section class="interactive-section">
            <h2>Sıra Sizde: Kendi Pi Sayını Bul!</h2>
            <p>Sınıftaki yuvarlak bir cismin çevresini ve çapını ölçüp sonuçları girin.</p>
            <input type="number" id="cevre" placeholder="Çevre (ör: 31.4)">
            <input type="number" id="cap" placeholder="Çap (ör: 10)">
            <br>
            <button onclick="piHesapla()">Hesapla</button>
            <h3 id="sonuc">Sonuç Bekleniyor...</h3>
            <p id="mesaj"></p>
        </section>

    </div>

    <!-- MODAL İÇERİKLERİ (Gizli Pencereler) -->
    <div id="modal1" class="modal">
        <div class="modal-content">
            <span class="close-btn" onclick="closeModal('modal1')">&times;</span>
            <h2 style="color: var(--primary-color);">Pi Sayısı Nedir? Detaylı Analiz</h2>
            <p>Antik Mısırlılar ve Babilliler döneminden beri bilinen Pi sayısı, en basit tabirle çemberin çevresinin çapına olan sabit oranıdır.</p>
            <p>Tarihte Arşimet, bir çemberin içine ve dışına çokgenler çizerek Pi sayısının değerini 3.1408 ile 3.1428 arasında olduğunu matematiksel olarak ispatlayan ilk kişilerden biridir. Sembolü olan "π", Yunanca "çevre" kelimesinin ilk harfidir.</p>
        </div>
    </div>

    <div id="modal2" class="modal">
        <div class="modal-content">
            <span class="close-btn" onclick="closeModal('modal2')">&times;</span>
            <h2 style="color: var(--primary-color);">Sonsuzluk ve Düzensizlik</h2>
            <p>Pi sayısı, kesirli bir şekilde yazılamayan <strong>İrrasyonel</strong> bir sayıdır.</p>
            <p>Örneğin 1/3 sayısı 0.33333... diye düzenli devreden bir şekilde sonsuza gider. Ancak Pi'nin virgülden sonrası (3,1415926535...) asla bir düzen tekrar etmez. Bu yüzden Pi, bilgisayarların işlem gücünü test etmek (Benchmark) için bile kullanılır. Milyarlarca basamak hesaplansa da asla bir kurala bağlanamaz.</p>
        </div>
    </div>

    <div id="modal3" class="modal">
        <div class="modal-content">
            <span class="close-btn" onclick="closeModal('modal3')">&times;</span>
            <h2 style="color: var(--primary-color);">Neden Çok Önemli?</h2>
            <p>Evrende içinde eğrilik, çember veya dalga bulunan her formülde Pi vardır!</p>
            <ul>
                <li><strong>Uzay Mühendisliği:</strong> Uyduların yörüngeye oturtulmasında.</li>
                <li><strong>Tıp:</strong> Gözün yapısını inceleyen lazer ölçümlerinde veya DNA sarmallarının hesaplanmasında.</li>
                <li><strong>Fizik:</strong> Işık dalgaları ve ses dalgalarının formüllerinde.</li>
            </ul>
        </div>
    </div>

    <footer>
        <p>Grup Üyeleri: [İsimleri Yazın] | Sınıf: [Sınıfı Yazın]</p>
        <p style="font-size: 0.8rem;">Güvenilir Kaynaklar: nasa.gov, britannica.com, bilimgenc.tubitak.gov.tr</p>
    </footer>

    <!-- JAVASCRIPT KODLARI -->
    <script>
        // Modal (Pop-up) Açma ve Kapatma Fonksiyonları
        function openModal(modalId) {
            document.getElementById(modalId).style.display = 'flex';
        }

        function closeModal(modalId) {
            document.getElementById(modalId).style.display = 'none';
        }

        // Modal dışına tıklanırsa kapatma
        window.onclick = function(event) {
            if (event.target.classList.contains('modal')) {
                event.target.style.display = "none";
            }
        }

        // Akordeon (SSS) Fonksiyonu
        function toggleFAQ(element) {
            element.classList.toggle("active");
            
            // Tıklanan sorunun sembolünü + veya - yapma
            let symbol = element.querySelector("span");
            if(element.classList.contains("active")) {
                symbol.innerText = "-";
            } else {
                symbol.innerText = "+";
            }
        }

        // Pi Hesaplama Fonksiyonu
        function piHesapla() {
            let cevre = document.getElementById('cevre').value;
            let cap = document.getElementById('cap').value;
            let sonucH3 = document.getElementById('sonuc');
            let mesajP = document.getElementById('mesaj');

            if(cevre && cap && cap != 0) {
                let hesaplananPi = (cevre / cap).toFixed(4);
                sonucH3.innerText = "Sizin Pi Sayınız: " + hesaplananPi;
                
                if(hesaplananPi >= 3.10 && hesaplananPi <= 3.20) {
                    mesajP.innerText = "🎯 Mükemmel ölçüm! Gerçek Pi değerine (3.1415...) çok yakın.";
                    mesajP.style.color = "#fff";
                } else {
                    mesajP.innerText = "📏 Sonuç biraz uzak çıktı. Mezura veya cetvelde kayma olmuş olabilir mi?";
                    mesajP.style.color = "#ffdd00";
                }
            } else {
                alert("Lütfen hem çevreyi hem de çapı doğru bir şekilde girin!");
            }
        }
    </script>
</body>
</html>
